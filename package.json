{
  "name": "mha-widget-hub",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "node --test",
    "check:secrets": "node tools/check-secrets.mjs",
    "check:syntax": "node tools/check-syntax.mjs",
    "check:package": "node tools/check-frontend-package.mjs",
    "check": "npm run check:secrets && npm run check:syntax && npm run check:icons && npm test && npm run check:package",
    "check:layout": "playwright test tests/geometry",
    "sync:frontend": "node tools/sync-integration-frontend.mjs",
    "build:integration": "node tools/build-integration-package.mjs",
    "generate:icons": "node tools/generate-tabler-icon-catalog.mjs",
    "check:icons": "node tools/generate-tabler-icon-catalog.mjs --check",
    "dev": "npm run sync:frontend",
    "build": "npm run check && npm run build:integration",
    "release:zip": "node tools/create-release-zip.mjs",
    "deploy:dev": "node tools/deploy-dev.mjs",
    "install:git-hooks": "node tools/install-git-hooks.mjs",
    "theme-studio": "node tools/theme-studio/server/index.js",
    "theme-studio:check": "node tools/theme-studio/check.mjs",
    "theme-studio:test": "node --test tests/theme-studio.test.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tabler/icons": "3.44.0"
  }
}
